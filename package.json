{
  "name": "resume-editor-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Resume editor chatbot migrated to Express for Hostinger deployment.",
  "main": "server.bundle.js",
  "scripts": {
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=server.bundle.js",
    "start": "node server.bundle.js",
    "dev": "node --watch server.bundle.js",
    "rag:index": "node server.bundle.js --index-documents",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "esbuild": "^0.25.3",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
